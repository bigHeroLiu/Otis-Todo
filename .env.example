# OPENAI_API_KEY: Standard OpenAI compatible API key
# Leave dummy or empty if using a local LLM with no auth required via OPENAI_BASE_URL
OPENAI_API_KEY="ollama"

# OPENAI_BASE_URL: Override this to point to a local standard LLM server
# For Ollama locally, use http://localhost:11434/v1
OPENAI_BASE_URL="http://localhost:11434/v1"

# LLM_MODEL: Model identifier to use. E.g., gemma4:31b
LLM_MODEL="gemma4:31b"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"
